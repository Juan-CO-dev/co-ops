# =============================================================================
# CO-OPS — Local Environment Template
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. This template (`.env.local.example`) is committed
# so anyone cloning the repo knows what's needed.
#
# To generate the three secret values (AUTH_JWT_SECRET, AUTH_PIN_PEPPER,
# AUTH_PASSWORD_PEPPER) locally, run:
#     npm run secrets:generate
# Copy the output into `.env.local` AND into Vercel env vars (Production +
# Preview + Development scopes).
# =============================================================================


# ---------- Supabase ---------------------------------------------------------
# From Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx-replace-me
SUPABASE_SERVICE_ROLE_KEY=xxx-replace-me-keep-secret


# ---------- Custom Auth ------------------------------------------------------
# AUTH_JWT_SECRET signs the JWTs our app issues. It MUST also be configured
# in Supabase as an HS256 *standby key* so PostgREST verifies our tokens and
# RLS sees `request.jwt.claim.*` natively.
#
# Setup:
#   Supabase Dashboard → JWT Keys → Create standby key
#   Algorithm: HS256
#   Key value: same string as AUTH_JWT_SECRET below (64 hex chars, no encoding)
#
# **FOOTGUN WARNING**: If AUTH_JWT_SECRET in this file and the standby key
# value in Supabase drift apart, *every authenticated request 500s*. Rotate
# them together — never one without the other. See
# docs/runbooks/jwt-rotation.md (written in Phase 2).
#
# Peppers are server-side-only constants prepended to PINs/passwords before
# bcrypt hashing. Rotating a pepper invalidates every existing PIN/password —
# treat them as one-time-set values.
AUTH_JWT_SECRET=xxx-generate-with-secrets-script-64-hex
AUTH_PIN_PEPPER=xxx-generate-with-secrets-script-64-hex
AUTH_PASSWORD_PEPPER=xxx-generate-with-secrets-script-64-hex


# ---------- Email (Resend) ---------------------------------------------------
RESEND_API_KEY=xxx-replace-me

# EMAIL_FROM: sender address for verification + reset emails.
# Use 'onboarding@resend.dev' until you've verified complimentsonly.com in Resend.
# After verification, swap to 'ops@complimentsonly.com' here AND in Vercel env vars.
EMAIL_FROM=onboarding@resend.dev


# ---------- Anthropic (Claude) -----------------------------------------------
# Server-side only. Used by /api/ai/route.ts. Model: claude-sonnet-4-6.
ANTHROPIC_API_KEY=xxx-replace-me


# ---------- Twilio (deferred per spec §2.8) ----------------------------------
# Adapter is scaffolded but disabled until A2P 10DLC clearance.
TWILIO_ACCOUNT_SID=xxx-replace-when-ready
TWILIO_AUTH_TOKEN=xxx-replace-when-ready
TWILIO_FROM_NUMBER=xxx-replace-when-ready
TWILIO_ENABLED=false


# ---------- Toast POS (deferred) ---------------------------------------------
TOAST_CLIENT_ID=xxx-replace-when-ready
TOAST_CLIENT_SECRET=xxx-replace-when-ready
TOAST_ENABLED=false


# ---------- 7shifts (deferred) -----------------------------------------------
SEVENSHIFTS_API_KEY=xxx-replace-when-ready
SEVENSHIFTS_ENABLED=false


# ---------- App config -------------------------------------------------------
# NEXT_PUBLIC_APP_URL — set per environment.
# Local: http://localhost:3000  •  Preview: Vercel preview URL  •  Production: production URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

SESSION_IDLE_MINUTES=10
SELF_EDIT_WINDOW_HOURS=3
