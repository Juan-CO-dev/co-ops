# Normalize line endings to LF on commit. Windows checkouts may render as
# CRLF locally based on autocrlf settings, but the repository contents stay
# LF — preserving cross-platform behavior of bash scripts and matching most
# tooling expectations.
* text=auto eol=lf

# Bash scripts MUST be LF — CRLF breaks shebang resolution.
*.sh        text eol=lf
*.bash      text eol=lf

# Windows-only files keep CRLF.
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binary files — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.pdf       binary
*.zip       binary

# Exclude from GitHub language stats.
package-lock.json   linguist-generated=true
