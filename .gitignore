# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block all real env files, allow only the example template
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# superpowers brainstorm artifacts (mockups, server state) — local only
.superpowers/

# Claude Code session metadata
.claude/

# Local secret-generation output
.env.local.generated.tmp

# Flash orchestration run-state (regenerated per run, not infra)
scripts/.flash-batch-results.json

# Local smoke/scratch scripts — untracked by design, tsc-red, never ship.
# Delete at launch (see docs/LAUNCH_PURGE_MANIFEST.md). Ignored here so they
# can't be accidentally committed and break main's build (cf. commit 324f2dd).
scripts/c55-*.ts
scripts/c53-phase2-smoke.ts
scripts/fix-test-pins.ts

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
